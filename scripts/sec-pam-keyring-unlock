#!/bin/bash
set -euo pipefail

unlock_keyring() {
    local auth_token="$1"

    [[ -n "$auth_token" ]] || return 0

    if ! pgrep -x "gnome-keyring-d" >/dev/null 2>&1; then
        gnome-keyring-daemon --start --daemonize --components=gpg,pkcs11,secrets,ssh >/dev/null 2>&1 || return 0
    fi

    printf '%s\n' "$auth_token" | gnome-keyring-daemon --unlock >/dev/null 2>&1 || return 0
}

if [[ "${PAM_TYPE:-}" == "auth" ]]; then
    if [[ -n "${PAM_USER:-}" && "$(id -un)" != "$PAM_USER" && "$(id -u)" -eq 0 ]]; then
        exit 0
    fi

    auth_token="${PAM_AUTHTOK:-}"
    if [[ -z "$auth_token" ]]; then
        IFS= read -r -s auth_token || true
    fi

    unlock_keyring "$auth_token"
    auth_token=""
    unset auth_token
    exit 0
fi

if pgrep -x "gnome-keyring-d" >/dev/null 2>&1 && printf '\n' | gnome-keyring-daemon --unlock >/dev/null 2>&1; then
    echo "Keyring already unlocked"
    exit 0
fi

if [[ ! -t 0 ]]; then
    exit 0
fi

echo -n "Enter keyring passphrase: "
read -r -s auth_token
echo

if [[ -z "$auth_token" ]]; then
    echo "No passphrase provided" >&2
    exit 1
fi

if unlock_keyring "$auth_token"; then
    echo "Keyring unlocked"
    auth_token=""
    unset auth_token
else
    echo "Failed to unlock keyring" >&2
    exit 1
fi
