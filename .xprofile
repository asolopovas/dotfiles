#!/bin/bash

export DOTFILES="$HOME/dotfiles"
export XPROFILE_LOADED=1

if [ -n "${DISPLAY:-}" ] && [ -z "${PS1:-}" ] && [ "${XSESSION_STDOUT_LOG_ACTIVE:-}" != 1 ]; then
    xsession_log_dir="${XDG_CACHE_HOME:-$HOME/.cache}/xsession"
    if mkdir -p "$xsession_log_dir"; then
        xsession_stdout_log="$xsession_log_dir/stdout.log"
        : >"$xsession_stdout_log" && export XSESSION_STDOUT_LOG_ACTIVE=1 && exec >>"$xsession_stdout_log"
    fi
    unset xsession_log_dir xsession_stdout_log
fi

env_vars=(
    env-vars
    include-paths
    xmonad-vars
)

source_script() {
    local script_name=$1
    local script_path="$DOTFILES/env/$script_name.sh"
    source "$script_path"
}

[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

for env_var in "${env_vars[@]}"; do
    source_script "$env_var"
done

session_id="${XDG_CURRENT_DESKTOP:-} ${DESKTOP_SESSION:-} ${GDMSESSION:-}"
shopt -s nocasematch
if [[ "$session_id" == *xmonad* ]] && command -v gnome-keyring-daemon >/dev/null 2>&1; then
    keyring_env=$(gnome-keyring-daemon --start --components=pkcs11,secrets,ssh 2>/dev/null || true)
    while IFS='=' read -r key value; do
        case "$key" in
            GNOME_KEYRING_CONTROL | SSH_AUTH_SOCK)
                export "$key=$value"
                ;;
        esac
    done <<<"$keyring_env"
fi
shopt -u nocasematch
unset session_id keyring_env

[ ! -d "$XMONAD_DATA_HOME" ] && mkdir -p "$XMONAD_DATA_HOME"
[ -x /usr/bin/numlockx ] && /usr/bin/numlockx on
