#!/bin/bash

export DOTFILES="$HOME/dotfiles"

env_vars=(
    env-vars
    include-paths
    xmonad-vars
)

source_script() {
    local script_name=$1
    local script_path="$DOTFILES/env/$script_name.sh"
    source $script_path
}

[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

for env_var in "${env_vars[@]}"; do
    source_script $env_var
done

[ ! -d "$XMONAD_DATA_HOME" ] && mkdir -p "$XMONAD_DATA_HOME"
[ -x /usr/bin/numlockx ] && /usr/bin/numlockx on
