#!/bin/bash
set -euo pipefail

repo="$(git rev-parse --show-toplevel)"
stamp="$repo/.git/pi-pre-commit-test"
cd "$repo"

test_key() {
    {
        git rev-parse HEAD
        git diff --binary
        git diff --cached --binary
        git ls-files --others --exclude-standard -z | while IFS= read -r -d '' file; do
            printf '%s\0' "$file"
            sha256sum "$file"
        done
    } | sha256sum | awk '{print $1}'
}

changed_files() {
    {
        if git rev-parse --verify HEAD >/dev/null 2>&1; then
            git diff --name-only HEAD --
        else
            git diff --cached --name-only --
        fi
        git ls-files --others --exclude-standard
    } | LC_ALL=C sort -u
}

key="$(test_key)"

if [[ "${1:-}" == "--record-only" ]]; then
    printf '%s\n' "$key" >"$stamp"
    exit 0
fi

if [[ -f "$stamp" && "$(<"$stamp")" == "$key" ]]; then
    echo "pre-commit: tests already passed"
    exit 0
fi

mapfile -t changed < <(changed_files)
mapfile -t suites < <(./tests/run-tests.sh --list-changed "${changed[@]}")

if [[ "${#changed[@]}" -eq 0 ]]; then
    echo "pre-commit: no changed files"
elif [[ "${#suites[@]}" -eq 0 ]]; then
    echo "pre-commit: no tests for changed files"
else
    echo "pre-commit: running tests: ${suites[*]}"
    make install-test-deps
    ./tests/run-tests.sh "${suites[@]}"
fi

printf '%s\n' "$key" >"$stamp"
