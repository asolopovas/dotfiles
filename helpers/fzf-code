#!/usr/bin/env bash
set -euo pipefail

dir=$HOME/.config/Code/User/globalStorage
db=$dir/state.vscdb
storage=$dir/storage.json
[[ -f $db ]] || { echo "VS Code DB not found: $db" >&2; exit 1; }

urldecode() { printf '%b' "${1//%/\\x}"; }

pick=$(sqlite3 -tabs "$db" "
WITH
  rj AS (SELECT value AS j FROM ItemTable
         WHERE key IN ('recently.opened','history.recentlyOpenedPathsList') LIMIT 1),
  recent AS (
    SELECT
      CASE
        WHEN json_extract(e.value,'\$.folderUri') IS NOT NULL THEN 'folder'
        WHEN json_extract(e.value,'\$.workspace') IS NOT NULL THEN 'workspace'
        WHEN json_extract(e.value,'\$.fileUri')   IS NOT NULL THEN 'file'
      END AS kind,
      COALESCE(json_extract(e.value,'\$.folderUri'),
               json_extract(e.value,'\$.workspace.configPath'),
               json_extract(e.value,'\$.fileUri')) AS uri
    FROM rj, json_each(rj.j,'\$.entries') e),
  store AS (
    SELECT CASE WHEN s.key LIKE '%.code-workspace' THEN 'workspace' ELSE 'folder' END AS kind,
           s.key AS uri
    FROM json_each(json_extract(readfile('$storage'),'\$.profileAssociations.workspaces')) s)
SELECT kind, uri FROM recent WHERE kind IS NOT NULL
UNION SELECT kind, uri FROM store;
" | awk -F'\t' -v OFS='\t' '
    {
        kind=$1; uri=$2
        if (match(uri, /^vscode-vfs:\/\/github(%2[Bb]|\+)[0-9a-fA-F]+/))
            uri = "vscode-vfs://github" substr(uri, RSTART+RLENGTH)
        if (seen[kind"\t"uri]++) next
        if      (uri ~ /^file:/)                  { p=0; tag="" }
        else if (uri ~ /^vscode-remote:\/\/ssh-/) { p=1; tag="ssh" }
        else if (uri ~ /^vscode-remote:/)         { p=1; tag="remote" }
        else if (uri ~ /^vscode-vfs:\/\/github/)  { p=2; tag="github" }
        else if (uri ~ /^vscode-vfs:/)            { p=2; tag="vfs" }
        else                                      { p=3; tag="" }
        if (tag=="github") { n=uri; sub(/^vscode-vfs:\/\/github\//,"",n) }
        else { n=uri; sub(/\/$/,"",n); sub(/.*\//,"",n) }
        if (kind=="workspace") { sub(/\.code-workspace$/,"",n); tag=tag?tag" ws":"ws" }
        if (tag) n = n " [" tag "]"
        if (shown[n]++) n = n " " shown[n]
        print p, n, kind, uri
    }' | sort -s | fzf --delimiter=$'\t' --with-nth=2 --no-multi) || exit 1

IFS=$'\t' read -r _ _ kind uri <<<"$pick"
case $kind:$uri in
    folder:file://*) exec code "$(urldecode "${uri#file://}")" ;;
    folder:*)        exec code --folder-uri "$uri" ;;
    *)               exec code --file-uri  "$uri" ;;
esac
