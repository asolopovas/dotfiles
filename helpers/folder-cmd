#!/bin/bash
# Fuzzy-pick a directory and open it with a given command
# Usage: folder-cmd <command>

result=$(fd -d 4 -H -t d \
    --base-directory ~ \
    --search-path . \
    --search-path ./www \
    --search-path ./git \
    -E .cache -E .config -E .local -E .npm -E .vscode-server \
    -E node_modules -E wp-includes -E vendor -E uploads -E .git | fzf)

if [ -z "$result" ]; then
    echo "No selection made." >&2
    exit 1
fi

result="${result#/}"

if [ "$1" = "phpstorm64.exe" ]; then
    winPath='\\wsl$\Ubuntu'
    result=$(echo "${winPath}${HOME}/${result}" | sed 's/\//\\/g')
    result="${result%\\}"
    "$1" "$result" >/dev/null 2>&1 &
    sleep 2
    exit
fi

"$1" "${HOME}/${result}"
