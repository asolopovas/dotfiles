#!/usr/bin/env bash

set -uo pipefail
trap '' INT QUIT

if ! command -v fzf >/dev/null; then
    echo "fzf is required"
    sleep 2
    exit 1
fi

sleep 0.2

TCOLS() { stty size 2>/dev/null | awk '{print $2}' || tput cols 2>/dev/null || echo 24; }
TLINES() { stty size 2>/dev/null | awk '{print $1}' || tput lines 2>/dev/null || echo 10; }

centered_fzf() {
    local header="$1"
    shift

    clear >&2

    local cols lines maxw o
    cols=$(TCOLS)
    lines=$(TLINES)
    [[ "$cols" =~ ^[0-9]+$ ]] || cols=80
    [[ "$lines" =~ ^[0-9]+$ ]] || lines=24

    maxw=0
    [[ -n "$header" && ${#header} -gt $maxw ]] && maxw=${#header}
    for o in "$@"; do
        ((${#o} > maxw)) && maxw=${#o}
    done

    local block content_h left right top bottom
    block=$((maxw + 6))
    ((block > cols)) && block=$cols
    left=$(((cols - block) / 2))
    right=$((cols - block - left))
    ((left < 0)) && left=0
    ((right < 0)) && right=0

    content_h=$(($# + 1))
    [[ -n "$header" ]] && content_h=$((content_h + 2))
    ((content_h > lines)) && content_h=$lines
    top=$(((lines - content_h) / 2))
    bottom=$((lines - content_h - top))
    ((top < 0)) && top=0
    ((bottom < 0)) && bottom=0

    local fzf_args=(
        --ansi
        --cycle
        +s
        --disabled
        --no-info
        --no-separator
        --border=none
        --prompt=""
        --pointer="▶ "
        --marker=""
        --margin="$top,$right,$bottom,$left"
        --padding="0,1"
        --color="pointer:212,fg+:212,header:212"
    )

    if [[ -n "$header" ]]; then
        fzf_args+=(--header="$header" --header-first)
    fi

    printf '%s\n' "$@" | fzf "${fzf_args[@]}"
}

ccenter_choose() {
    centered_fzf "" "$@"
}

unmount_safestore() {
    local pid
    pid=$(pgrep -x Cryptomator || true)
    if [[ -n "$pid" ]]; then
        kill -TERM "$pid" 2>/dev/null || true
        sleep 1
    fi
    if mountpoint -q "$HOME/safestore" 2>/dev/null; then
        fusermount -uz "$HOME/safestore" 2>/dev/null || true
    fi
}

logout_xmonad() {
    local xpid
    xpid=$(pidof -s xmonad-x86_64-linux || true)
    [[ -n "$xpid" ]] && kill -TERM "$xpid"
}

confirm() {
    local choice
    choice=$(centered_fzf "$1" "Yes" "No") || return 1
    [[ "$choice" == "Yes" ]]
}

while :; do
    choice=$(ccenter_choose \
        "Lock" \
        "Logout" \
        "Suspend" \
        "Reboot" \
        "Shutdown" \
        "Halt") || exit 0
    case "$choice" in
        Lock)
            if command -v slock >/dev/null; then
                slock &
                exit 0
            elif command -v xsecurelock >/dev/null; then
                xsecurelock &
                exit 0
            elif command -v i3lock >/dev/null; then
                i3lock &
                exit 0
            elif command -v xscreensaver-command >/dev/null; then
                xscreensaver-command -lock &
                exit 0
            else
                printf '%s\n' "no screen locker found" >&2
                sleep 1.5
            fi
            ;;
        Logout)
            confirm "Logout of xmonad?" || continue
            unmount_safestore
            logout_xmonad
            exit 0
            ;;
        Suspend)
            confirm "Suspend the system?" || continue
            systemctl suspend
            exit 0
            ;;
        Reboot)
            confirm "Reboot now?" || continue
            unmount_safestore
            systemctl reboot
            exit 0
            ;;
        Shutdown)
            confirm "Shut down now?" || continue
            unmount_safestore
            systemctl poweroff
            exit 0
            ;;
        Halt)
            confirm "Halt the system?" || continue
            unmount_safestore
            systemctl halt
            exit 0
            ;;
        "")
            exit 0
            ;;
    esac
done
