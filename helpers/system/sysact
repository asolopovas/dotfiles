#!/usr/bin/env bash

set -uo pipefail
trap '' INT QUIT

if ! command -v fzf >/dev/null; then
    echo "fzf is required"
    sleep 2
    exit 1
fi

sleep 0.2

centered_fzf() {
    local header="$1"
    shift

    clear >&2

    local fzf_args=(
        --ansi
        --cycle
        +s
        --no-info
        --prompt=""
        --pointer="▶ "
        --color="pointer:212,fg+:212,header:212"
    )

    if [[ -n "$header" ]]; then
        fzf_args+=(--header="$header")
    fi

    local output status
    output=$(printf '%s\n' "$@" | fzf "${fzf_args[@]}")
    status=$?
    if ((status == 2)); then
        printf '%s\n' "fzf failed" >&2
        sleep 2
    fi
    printf '%s\n' "$output"
    return "$status"
}

ccenter_choose() {
    centered_fzf "" "$@"
}

unmount_safestore() {
    local pid
    pid=$(pgrep -x Cryptomator || true)
    if [[ -n "$pid" ]]; then
        kill -TERM "$pid" 2>/dev/null || true
        sleep 1
    fi
    if mountpoint -q "$HOME/safestore" 2>/dev/null; then
        fusermount -uz "$HOME/safestore" 2>/dev/null || true
    fi
}

logout_xmonad() {
    local xpid
    xpid=$(pidof -s xmonad-x86_64-linux || true)
    [[ -n "$xpid" ]] && kill -TERM "$xpid"
}

confirm() {
    local choice
    choice=$(centered_fzf "$1" "Yes" "No") || return 1
    [[ "$choice" == "Yes" ]]
}

while :; do
    choice=$(ccenter_choose \
        "Lock" \
        "Logout" \
        "Suspend" \
        "Reboot" \
        "Shutdown" \
        "Halt") || exit 0
    case "$choice" in
        Lock)
            if command -v slock >/dev/null; then
                slock &
                exit 0
            elif command -v xsecurelock >/dev/null; then
                xsecurelock &
                exit 0
            elif command -v i3lock >/dev/null; then
                i3lock &
                exit 0
            elif command -v xscreensaver-command >/dev/null; then
                xscreensaver-command -lock &
                exit 0
            else
                printf '%s\n' "no screen locker found" >&2
                sleep 1.5
            fi
            ;;
        Logout)
            confirm "Logout of xmonad?" || continue
            unmount_safestore
            logout_xmonad
            exit 0
            ;;
        Suspend)
            confirm "Suspend the system?" || continue
            systemctl suspend
            exit 0
            ;;
        Reboot)
            confirm "Reboot now?" || continue
            unmount_safestore
            systemctl reboot
            exit 0
            ;;
        Shutdown)
            confirm "Shut down now?" || continue
            unmount_safestore
            systemctl poweroff
            exit 0
            ;;
        Halt)
            confirm "Halt the system?" || continue
            unmount_safestore
            systemctl halt
            exit 0
            ;;
        "")
            exit 0
            ;;
    esac
done
