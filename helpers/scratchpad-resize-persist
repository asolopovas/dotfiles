#!/usr/bin/env bash
set -euo pipefail

cls="${1:-}"
size="${2:-}"
config="$HOME/.config/xmonad/config.json"
cache_dir="$HOME/.cache/xmonad"
cache_file="$cache_dir/scratchpad-sizes"

[[ -z "$cls" || -z "$size" ]] && exit 0

case "$size" in
    small | medium | large | center) ;;
    *) exit 0 ;;
esac

mkdir -p "$cache_dir"
touch "$cache_file"
live_tmp=$(mktemp)
trap 'rm -f "$live_tmp" "${tmp:-}"' EXIT
awk -v name="$cls" '$1 != name' "$cache_file" > "$live_tmp"
printf '%s %s\n' "$cls" "$size" >> "$live_tmp"
cat "$live_tmp" > "$cache_file"

[[ -f "$config" ]] || exit 0

tmp=$(mktemp)

if jq --arg c "$cls" --arg s "$size" '
    ([ (.scratchpads // [])[] | select((.name // "") == $c and (.matchBy // "") == "className") | .match ] | first) as $sn_cn
    | (if (.scratchpads // []) | map(.match // "") | index($c) then $c else null end) as $sm_cn
    | (if (.scratchpads // []) | map(.name // "") | index($c) then $sn_cn
       elif $sm_cn != null then $sm_cn
       else $c end) as $cn
    | (if (.scratchpads // []) | map(.name // "") | index($c) then
           .scratchpads |= map(if (.name // "") == $c then .float = $s else . end)
       elif (.scratchpads // []) | map(.match // "") | index($c) then
           .scratchpads |= map(if (.match // "") == $c then .float = $s else . end)
       else . end)
    | (if $cn != null and ((.windowRules // []) | map(.className // "") | index($cn)) then
           .windowRules |= map(if (.className // "") == $cn then .float = $s else . end)
       else . end)
' "$config" > "$tmp"; then
    if ! cmp -s "$tmp" "$config"; then
        cat "$tmp" > "$config"
    fi
fi
