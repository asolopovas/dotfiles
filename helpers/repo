#!/bin/bash

OWNER="${REPO_OWNER:-asolopovas}"
CACHE_TTL="${REPO_CACHE_TTL:-21600}"
REPO_LIMIT="${REPO_LIMIT:-1000}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
CACHE_DIR="$XDG_CACHE_HOME/dotfiles"
CACHE_FILE="$CACHE_DIR/repos-$OWNER"
USE_HTTPS=false
PICK_REPO=false
REPO_NAME=""

usage() {
    printf '%s\n' "Usage: repo [--https] [REPO]" "       repo --pick" "       repo --list" "       repo --refresh-cache"
}

cache_age() {
    if [ ! -f "$CACHE_FILE" ]; then
        printf '%s\n' 999999999
        return
    fi

    local now modified
    now=$(date +%s)
    modified=$(stat -c %Y "$CACHE_FILE" 2>/dev/null || stat -f %m "$CACHE_FILE" 2>/dev/null || printf '%s\n' 0)
    printf '%s\n' "$((now - modified))"
}

refresh_cache() {
    command -v gh >/dev/null 2>&1 || return 1
    mkdir -p "$CACHE_DIR"

    local lock tmp status
    lock="$CACHE_FILE.lock"
    tmp="$CACHE_FILE.tmp.$$"

    if ! mkdir "$lock" 2>/dev/null; then
        return 0
    fi

    gh repo list "$OWNER" --limit "$REPO_LIMIT" --json name,description --template '{{range .}}{{.name}}{{"\t"}}{{.description}}{{"\n"}}{{end}}' >"$tmp"
    status=$?

    if [ $status -eq 0 ] && [ -s "$tmp" ]; then
        mv "$tmp" "$CACHE_FILE"
    else
        rm -f "$tmp"
    fi

    rmdir "$lock" 2>/dev/null || true
    return $status
}

list_repos() {
    if [ ! -f "$CACHE_FILE" ]; then
        refresh_cache >/dev/null 2>&1 || true
    elif [ "$(cache_age)" -gt "$CACHE_TTL" ]; then
        "$0" --refresh-cache >/dev/null 2>&1 &
    fi

    [ -f "$CACHE_FILE" ] && cat "$CACHE_FILE"
}

pick_repo() {
    command -v fzf >/dev/null 2>&1 || {
        printf '%s\n' "fzf is required for interactive repo selection" >&2
        return 1
    }

    local repos selection self reload_cmd
    repos=$(list_repos)
    if [ -z "$repos" ]; then
        printf '%s\n' "No repositories found. Run repo --refresh-cache or check gh auth." >&2
        return 1
    fi

    self=$(printf '%q' "$0")
    reload_cmd="$self --refresh-cache >/dev/null 2>&1; $self --list"
    selection=$(printf '%s\n' "$repos" | fzf \
        --height "${REPO_FZF_HEIGHT:-80%}" \
        --layout reverse \
        --border \
        --prompt "$OWNER> " \
        --delimiter=$'\t' \
        --with-nth 1,2 \
        --nth 1,2 \
        --no-multi \
        --header "enter: clone  ctrl-r: refresh" \
        --bind "ctrl-r:reload($reload_cmd)") || return 1

    [ -n "$selection" ] || return 1
    printf '%s\n' "${selection%%$'\t'*}"
}

clone_repo() {
    local input repo_dir repo_url
    input="$1"

    case "$input" in
        http://*|https://*|git@*)
            repo_url="$input"
            repo_dir=${input##*/}
            repo_dir=${repo_dir%.git}
            ;;
        */*)
            repo_dir=${input##*/}
            if [ "$USE_HTTPS" = true ]; then
                repo_url="https://github.com/$input.git"
            else
                repo_url="git@github.com:$input.git"
            fi
            ;;
        *)
            repo_dir="$input"
            if [ "$USE_HTTPS" = true ]; then
                repo_url="https://github.com/$OWNER/$input.git"
            else
                repo_url="git@github.com:$OWNER/$input.git"
            fi
            ;;
    esac

    if [ -d "$repo_dir" ]; then
        printf '%s\n' "REPO $repo_dir already exists" >&2
        return 1
    fi

    git clone "$repo_url"
}

while [ $# -gt 0 ]; do
    case "$1" in
        --https)
            USE_HTTPS=true
            ;;
        --pick|--fzf)
            PICK_REPO=true
            ;;
        --list|--complete)
            list_repos
            exit 0
            ;;
        --refresh-cache)
            refresh_cache
            exit $?
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --*)
            printf '%s\n' "Unrecognized argument: $1" >&2
            usage >&2
            exit 1
            ;;
        *)
            if [ -z "$REPO_NAME" ]; then
                REPO_NAME="$1"
            else
                printf '%s\n' "Unrecognized argument: $1" >&2
                usage >&2
                exit 1
            fi
            ;;
    esac
    shift
done

if [ -z "$REPO_NAME" ]; then
    if [ "$PICK_REPO" = true ] || [ -t 0 ]; then
        REPO_NAME=$(pick_repo) || exit $?
    else
        usage >&2
        exit 1
    fi
fi

clone_repo "$REPO_NAME"
