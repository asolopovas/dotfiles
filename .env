# default zsh directory
export ZDOTDIR="$HOME/.config/zsh"

# Load custom scripts
load_scripts() {
  if [ -d "${HOME}${1}" ]; then
    scriptsPath="$scriptsPath:$(du "${HOME}${1}" | cut -f2 | tr '\n' ':' | sed 's/:*$//')"
  fi
}
load_scripts /.local/bin
load_scripts /.local/share/gem/bin
load_scripts /.config/composer/vendor/bin
load_scripts /.local/yarn/bin
load_scripts /.yarn/bin
load_scripts /.config/fzf/bin

export PATH="$PATH:$scriptsPath"

# FZF default command
FZF_COMMAND='rg --files --no-ignore --hidden --follow -g "!.git/*" -g "!.steam/*" -g "!.local/share" -g "!.local/usr/bin" -g "!node_modules/*" -g "!vendor/*" 2> /dev/null'

export FZF_DEFAULT_COMMAND=$FZF_COMMAND
export FZF_CTRL_T_COMMAND=$FZF_COMMAND

# Docker
export DOCKER_BUILDKIT=1
export COMPOSE_DOCKER_CLI_BUILD=1
