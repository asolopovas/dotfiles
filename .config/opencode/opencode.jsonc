{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-claude-auth"
  ],
  "command": {
    "gw": {
      "template": "commit and push",
      "description": "Commit and push"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    }
  }
}
