{
  "_comment": "Edit this file and run `xmonad --restart` (or M-<F5>) to apply key changes. Window rules take effect on the next new window with no restart.",

  "terminal":           "alacritty",
  "browser":            "$BROWSER",
  "filebrowser":        "thunar",
  "modMask":            "mod4",
  "borderWidth":        1,
  "normalBorderColor":  "#dddddd",
  "focusedBorderColor": "#fff323",
  "focusFollowsMouse":  false,
  "clickJustFocuses":   false,
  "workspaces":         ["1","2","3","4","5","6","7","8","9"],

  "keys": {
    "M-q":               "kill",
    "M-S-q":             "kill-all",
    "M-s":               "focus-master",
    "M-j":               "focus-down",
    "M-k":               "focus-up",
    "M-S-j":             "swap-down",
    "M-S-k":             "swap-up",
    "M-<Backspace>":     "promote",
    "M-f":               "toggle-full",
    "M-S-<Space>":       "toggle-mirror",
    "M-S-y":             "expand",
    "M-S-o":             "shrink",
    "M-S-u":             "mirror-expand",
    "M-S-i":             "mirror-shrink",
    "M-S-0":             "reset-layout",
    "M-.":               "increment-master",
    "M-,":               "decrement-master",
    "M-<Delete>":        "sink",
    "M-t":               "toggle-float",

    "M-<Return>":        "spawn:alacritty",
    "M-0":               "spawn:sysact",
    "M-p":               "spawn:fzf-menu fzf-thunar",
    "M-o":               "spawn:fzf-menu fzf-code",
    "M-S-p":             "spawn:fzf-menu fzf-alacritty",

    "M-<F5>":            "reload-config",
    "M-<F6>":            "recompile",
    "M-<F7>":            "edit-config",
    "M-<F12>":           "spawn:alacritty --class=xmonad-config -o window.dimensions.columns=110 -o window.dimensions.lines=40 -t xmonad-config -e xmonad-config",
    "M-S-e":             "exit",

    "M-c":               "scratchpad:brave",
    "M-m":               "scratchpad:aimp",
    "M-b":               "scratchpad:firefox",
    "M-x":               "scratchpad:filebrowser",
    "M-S-<Return>":      "scratchpad:terminal",
    "<F1>":              "scratchpad:help",
    "<F6>":              "scratchpad:thunderbird",
    "<F8>":              "scratchpad:stacer",
    "<F7>":              "spawn:aimp-delete-track",
    "<XF86Launch6>":     "scratchpad:pavucontrol",
    "<XF86Calculator>":  "scratchpad:calc",

    "<XF86AudioLowerVolume>":  "spawn:lmc down",
    "<XF86AudioRaiseVolume>":  "spawn:lmc up",
    "<XF86AudioMute>":         "spawn:pamixer --toggle-mute",
    "<XF86AudioPlay>":         "spawn:playerctl play-pause",
    "<XF86MonBrightnessUp>":   "spawn:brightnessctl set +5%",
    "<XF86MonBrightnessDown>": "spawn:brightnessctl set 5%-",
    "<XF86AudioStop>":         "spawn:playerctl stop",
    "<XF86AudioPrev>":         "spawn:playerctl previous",
    "<XF86AudioNext>":         "spawn:playerctl next",
    "<Print>":                 "spawn:flameshot gui",
    "<XF86MenuPB>":            "spawn:flameshot gui"
  },

  "scratchpads": [
    { "name": "firefox",     "command": "firefox --class='FirefoxScratchpad' --enable-features=WebUIDarkMode --force-dark-mode", "matchBy": "className", "match": "FirefoxScratchpad", "float": "tile" },
    { "name": "brave",       "command": "sh -c '$BROWSER --class=BraveScratchpad'", "matchBy": "className", "match": "BraveScratchpad",   "float": "tile" },
    { "name": "filebrowser", "command": "thunar",              "matchBy": "className", "match": "Thunar",           "float": "large" },
    { "name": "terminal",    "command": "alacritty -t scratchpad", "matchBy": "title", "match": "scratchpad",       "float": "medium" },
    { "name": "stacer",      "command": "sudo -A /usr/bin/stacer > /tmp/stacer.log", "matchBy": "className", "match": "stacer", "float": "medium" },
    { "name": "pavucontrol", "command": "pavucontrol",         "matchBy": "className", "match": "Pavucontrol",      "float": "medium" },
    { "name": "spotify",     "command": "spotify",             "matchBy": "className", "match": "Spotify",          "float": "large" },
    { "name": "aimp",        "command": "aimp",                "matchBy": "className", "match": "Aimp",             "float": "large" },
    { "name": "chatGPT",     "command": "chat-gpt",            "matchBy": "className", "match": "Chat-gpt",         "float": "large" },
    { "name": "thunderbird", "command": "thunderbird",         "matchBy": "className", "match": "thunderbird",      "float": "large" },
    { "name": "calc",        "command": "gnome-calculator",    "matchBy": "className", "match": "Gnome-calculator", "float": "large" },
    { "name": "help",        "command": "alacritty --class help-viewer,help-viewer -o window.dimensions.columns=82 -o window.dimensions.lines=50 -e glow -w 90 -p ~/dotfiles/docs/help.md", "matchBy": "appName", "match": "help-viewer", "float": { "x": 0.25, "y": 0.1, "w": 0.5, "h": 0.8 } }
  ],

  "windowRules": [
    { "className": "Gimp",                      "float": "center" },
    { "className": "Pavucontrol",               "float": "center" },
    { "className": "qt5ct",                     "float": "center" },
    { "className": "Nm-connection-editor",      "float": "center" },
    { "className": "Gnome-builder",             "float": "center" },
    { "className": "Org.gnome.Software",        "float": "center" },
    { "className": "Libfm-pref-apps",           "float": "center" },
    { "className": "pavucontrol",               "float": "center" },
    { "className": "vlc",                       "float": "medium" },
    { "className": "Insync",                    "float": "medium" },
    { "className": "Viewnior",                  "float": "center" },
    { "className": "Barrier",                   "float": "center" },
    { "className": "stacer",                    "float": "center" },
    { "className": "Lxappearance",              "float": "center" },
    { "className": "Vmware",                    "float": "center" },
    { "className": "Nvidia-settings",           "float": "center" },
    { "className": "Hexchat",                   "float": "center" },
    { "className": "p3x-onenote",               "float": "center" },
    { "className": "Viewnioprogramr",           "float": "center" },
    { "className": "Blueman-manager",           "float": "medium" },
    { "className": "Catfish",                   "float": "center" },
    { "className": "Gpg-crypter",               "float": "center" },
    { "className": "kcachegrind",               "float": "center" },
    { "className": "Qalculate-gtk",             "float": "center" },
    { "className": "flameshot",                 "float": "large" },
    { "className": "Anydesk",                   "float": "medium" },
    { "className": "Psi",                       "float": "center" },
    { "className": "Xviewer",                   "float": "center" },
    { "className": "Image Lounge",              "float": "center" },
    { "className": "Seahorse",                  "float": "center" },
    { "className": "Xarchiver",                 "float": "center" },
    { "className": "Aimp",                      "float": "center" },
    { "className": "TelegramDesktop",           "float": "large" },
    { "className": "Signal",                    "float": "large" },
    { "className": "Skype",                     "float": "large" },
    { "className": "Teamviewer",                "float": "large" },
    { "className": "Windscribe2",               "float": "float" },
    { "className": "whatsapp-nativefier-d40211","workspace": "1_7" },
    { "appName":   "fzf-menu",                  "float": "center" },
    { "className": "xmonad-config",              "float": "large"  },
    { "appName":   "pcmanfmTerm",               "float": "center" },
    { "appName":   "gnome-tweaks",              "float": "center" },
    { "appName":   "gnome-calculator",          "float": "small"  },
    { "appName":   "xdg-desktop-portal-gnome",  "float": "center" },
    { "role":      "GtkFileChooserDialog",      "float": "center" },
    { "role":      "pop-up",                    "float": "center" },
    { "title":     "Picture-in-picture",        "float": "small"  },
    { "title":     "Media viewer",              "float": "center" },
    { "title":     "Cryptomator",               "float": "medium" },
    { "title":     "Bitwarden",                 "float": "float"  },
    { "className": "Thunar", "titleSuffix": "- Thunar", "float": "center" }
  ]
}
