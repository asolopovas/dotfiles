{
  // Tslint on save
  "tslint.enable": true,
  "tslint.autoFixOnSave": true,

  "emmet.includeLanguages": {
    "vue": "html",
    "markdown": "html",
    "javascript": "javascriptreact",
    "twig": "html",
    "block.js": "html",
    "php": "html",
    "blade": "html"
  },
  // Run prettier (and others)
  "coc.preferences.formatOnSaveFiletypes": [
    "css",
    "markdown",
    "Markdown",
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ]
}

